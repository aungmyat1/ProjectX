{
  "gateway": {
    "mode": "local"
  },
  "agents": {
    "defaults": {
      "workspace": "<PROJECTX_ROOT>/workspace",
      "model": { "primary": "openrouter:google/gemini-2.0-flash-001" }
    },
    "list": [
      {
        "id": "main",
        "default": true,
        "name": "ProjectX Main",
        "workspace": "<PROJECTX_ROOT>/workspace"
      }
    ]
  }
}
