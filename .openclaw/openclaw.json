{
  "meta": {
    "version": "2026.3.13",
    "deploymentType": "projectx-integrated",
    "optimizedFor": "multi-agent-vps"
  },
  "gateway": {
    "mode": "local",
    "bind": "lan",
    "port": 3210,
    "auth": {
      "mode": "token",
      "token": "px-13343f5449dc84d4f55c1550523e16d5a8b2c9f4e7a1b0d8"
    },
    "controlUi": {
      "allowedOrigins": [
        "file://",
        "https://your-domain.com",
        "http://localhost:3000"
      ]
    }
  },
  "browser": {
    "enabled": true,
    "defaultProfile": "openclaw",
    "headless": false
  },
  "agents": {
    "defaults": {
      "workspace": "C:/ProjectX/workspace",
      "models": {
        "openrouter/google/gemini-flash-1.5": {
          "alias": "fast",
          "params": {
            "maxTokens": 1000,
            "temperature": 0.3
          }
        },
        "openrouter/minimax/minimax-01": {
          "alias": "default",
          "params": {
            "maxTokens": 2000
          }
        },
        "openrouter/deepseek/deepseek-chat": {
          "alias": "coding",
          "params": {
            "maxTokens": 2000
          }
        },
        "openrouter/anthropic/claude-3.5-sonnet": {
          "alias": "analysis",
          "params": {
            "maxTokens": 3000,
            "temperature": 0.2
          }
        }
      },
      "model": {
        "primary": "openrouter/minimax/minimax-01",
        "fallbacks": [
          "openrouter/google/gemini-flash-1.5",
          "openrouter/anthropic/claude-3.5-sonnet"
        ]
      },
      "bootstrapMaxChars": 12000,
      "bootstrapTotalMaxChars": 80000,
      "contextPruning": {
        "mode": "cache-ttl"
      },
      "compaction": {
        "maxHistoryShare": 0.6,
        "recentTurnsPreserve": 3,
        "model": "openrouter/minimax/minimax-01",
        "memoryFlush": {
          "enabled": true
        }
      },
      "heartbeat": {
        "model": "openrouter/google/gemini-flash-1.5",
        "lightContext": true,
        "every": "30m",
        "activeHours": {
          "start": "08:00",
          "end": "22:00",
          "timezone": "Asia/Rangoon"
        }
      },
      "subagents": {
        "model": "openrouter/minimax/minimax-01",
        "maxConcurrent": 4
      },
      "maxConcurrent": 2
    },
    "list": [
      {
        "id": "main",
        "default": true,
        "name": "ClawX Main Assistant",
        "workspace": "C:/ProjectX/workspace",
        "description": "Primary personal assistant with full capabilities"
      },
      {
        "id": "analysis",
        "name": "Heavy Reasoning",
        "workspace": "C:/ProjectX/workspace-analysis",
        "model": {
          "primary": "openrouter/anthropic/claude-3.5-sonnet"
        },
        "description": "Heavy reasoning and high-stakes analysis (use sparingly)"
      },
      {
        "id": "vps",
        "name": "VPS Manager",
        "workspace": "C:/ProjectX/workspace-vps",
        "model": {
          "primary": "openrouter/deepseek/deepseek-chat"
        },
        "description": "VPS infrastructure management and DevOps specialist",
        "tools": {
          "allow": ["exec", "read", "write", "edit", "web_search", "sessions_spawn"]
        }
      }
    ]
  },
  "tools": {
    "profile": "full",
    "sessions": {
      "visibility": "all"
    }
  },
  "commands": {
    "native": "auto",
    "nativeSkills": "auto",
    "restart": true,
    "ownerDisplay": "raw"
  },
  "channels": {
    "discord": {
      "enabled": true,
      "token": "YOUR_DISCORD_BOT_TOKEN_HERE",
      "groupPolicy": "allowlist",
      "dm": {
        "enabled": false
      },
      "retry": {
        "attempts": 3,
        "minDelayMs": 500,
        "maxDelayMs": 30000,
        "jitter": 0.1
      },
      "guilds": {
        "1221046992050982962": {
          "users": ["*"],
          "requireMention": true,
          "channels": {
            "*": {
              "allow": true,
              "requireMention": true
            }
          }
        }
      }
    }
  },
  "messages": {
    "ackReactionScope": "group-mentions"
  }
}
